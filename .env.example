# Server Configuration
PORT=3000

# Admin Authentication
# IMPORTANT: Set a strong password (at least 16 characters with mixed case, numbers, and symbols)
# Example: MyP@ssw0rd!2024
ADMIN_PASSWORD=your-secure-password-here

# Session Security
# IMPORTANT: Generate a random secret key with: openssl rand -base64 32
# This must be at least 32 characters and should be kept secret
# Example: aBcDeFgHiJkLmNoPqRsTuVwXyZ1234567890
SESSION_SECRET=random-long-secret-key-min-32-characters
